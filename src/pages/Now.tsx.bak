                      <div className="text-sm text-zinc-400 font-light leading-relaxed mb-4">{item.description}</div>
                      <StatusBadge 
                        status={item.status} 
                        color={i === 0 ? "emerald" : "amber"} 
                        animated={i === 0}
                      />
                    </div>
                  </div>
                </motion.div>
              ))}
            </div>
          </div>

          {/* Researching Section */}
          <div className="mb-16">
