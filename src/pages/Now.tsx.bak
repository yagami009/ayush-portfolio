                  transition={{ duration: 0.55, delay: i * 0.08, ease: [0.16, 1, 0.3, 1] }}
                  whileHover={{ backgroundColor: "rgba(255,255,255,0.02)" }}
                  className="py-8 border-b border-zinc-800 cursor-pointer transition-colors px-4 -mx-4"
                >
                  <div className="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-6 items-start">
                    <span className="font-mono text-xs text-zinc-500 pt-1">0{i + 1}</span>
                    <div>
                      <div className="font-serif text-lg font-light text-zinc-50 mb-2">{item.title}</div>
                      <div className="text-sm text-zinc-400 font-light leading-relaxed mb-4">{item.description}</div>
                      <StatusBadge status={item.status} color="zinc" />
                    </div>
                  </div>
