                  whileHover={{ backgroundColor: "rgba(255,255,255,0.02)" }}
                  className="py-8 border-b border-zinc-800 cursor-pointer transition-colors px-4 -mx-4"
                >
                  <div className="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr] gap-6 items-start">
