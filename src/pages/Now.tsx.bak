import { motion, useInView } from "framer-motion";
import { useRef } from "react";
import { siteContent } from "../content";

const fadeUp = (delay: number = 0) => ({
  initial: { opacity: 0, y: 18 },
  animate: { opacity: 1, y: 0 },
  transition: { duration: 0.55, ease: [0.16, 1, 0.3, 1], delay },
});

function SectionRule({ label }: { label: string }) {
  const ref = useRef(null);
  const inView = useInView(ref, { once: true, margin: "-80px" });
  
  return (
    <motion.div
      ref={ref}
      initial={{ opacity: 0, y: 12 }}
      animate={inView ? { opacity: 1, y: 0 } : {}}
      transition={{ duration: 0.55, ease: [0.16, 1, 0.3, 1] }}
      className="flex items-center gap-4 mb-8"
    >
      <span className="font-mono text-xs text-zinc-500 uppercase tracking-wider whitespace-nowrap">{label}</span>
      <div className="flex-1 h-px bg-zinc-800"></div>
    </motion.div>
  );
}

interface StatusProps {
  status: string;
  color: "emerald" | "amber" | "zinc";
  animated?: boolean;
}

function StatusBadge({ status, color, animated = false }: StatusProps) {
  const colorMap = {
    emerald: "bg-emerald-500 text-emerald-400",
    amber: "bg-amber-500 text-amber-400",
    zinc: "bg-zinc-500 text-zinc-400",
  };

  return (
    <div className="flex items-center gap-2">
      <span 
        className={`w-1.5 h-1.5 rounded-full ${colorMap[color].split(" ")[0]}`}
        style={{ animation: animated ? "pulse 2s ease-in-out infinite" : "none" }}
      />
      <span className="font-mono text-xs uppercase tracking-wider text-zinc-500">{status}</span>
    </div>
  );
}

export function Now() {
  const { nowPage } = siteContent;

  return (
    <div className="min-h-screen pt-24">
      {/* Hero */}
      <div className="py-16 px-6 md:px-12 border-b border-zinc-800">
        <div className="max-w-6xl mx-auto">
          <motion.div {...fadeUp(0.1)} className="flex items-center gap-3 mb-6">
            <span className="w-2 h-2 rounded-full bg-teal-500"></span>
            <span className="font-mono text-xs text-teal-500 uppercase tracking-wider">Now</span>
          </motion.div>

          <motion.h1 {...fadeUp(0.2)} className="text-4xl md:text-5xl font-serif font-light text-zinc-50 leading-tight mb-6">
            What I&apos;m <span className="text-zinc-500">working on</span>
          </motion.h1>

          <motion.p {...fadeUp(0.3)} className="text-lg text-zinc-400 font-light max-w-2xl mb-8">
            A live view of where my attention is. Inspired by Derek Sivers&apos; /now page idea. Updated when things change significantly.
          </motion.p>

          <motion.div {...fadeUp(0.4)} className="flex items-center gap-2 font-mono text-xs text-zinc-500">
            <span 
              className="w-1.5 h-1.5 rounded-full bg-emerald-500"
              style={{ animation: "pulse 2.5s ease-in-out infinite" }}
            />
            Last updated: {nowPage.lastUpdated} · {nowPage.location}
          </motion.div>
        </div>
      </div>

      <div className="py-16 px-6 md:px-12">
        <div className="max-w-6xl mx-auto">
          {/* Building Section */}
          <div className="mb-16">
            <SectionRule label="Building" />
            
            <div className="space-y-0">
              {nowPage.building.map((item, i) => (
